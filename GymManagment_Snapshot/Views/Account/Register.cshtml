@using GymManagment.BLL.ViewModels.RegisterViewModels
@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null; // Standalone page matching login style
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Route Fitness</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            background-color: #f3f4f6; /* Light gray background matching the edges */
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .auth-container {
            display: flex;
            background: #fff;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            max-width: 1000px;
            width: 90%;
            min-height: 600px;
        }

        /* Left Side: Form */
        .auth-form-section {
            flex: 1;
            padding: 40px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .auth-logo {
            text-align: center;
            margin-bottom: 20px;
        }

            .auth-logo img {
                width: 50px;
                margin-bottom: 10px;
            }

        .auth-title {
            text-align: center;
            font-weight: bold;
            color: #0b1354;
            margin-bottom: 5px;
        }

        .auth-subtitle {
            text-align: center;
            color: #6c757d;
            font-size: 0.9rem;
            margin-bottom: 30px;
        }

        .input-group-text {
            background: transparent;
            border-right: none;
            color: #6c757d;
        }

        .form-control {
            border-left: none;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: #dee2e6;
            }

        .input-group:focus-within {
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
            border-radius: 0.375rem;
        }

            .input-group:focus-within .input-group-text,
            .input-group:focus-within .form-control {
                border-color: #86b7fe;
            }

        .toggle-password {
            cursor: pointer;
            background: transparent;
            border-left: none;
            border-right: 1px solid #dee2e6; /* Match standard border */
            border-top: 1px solid #dee2e6;
            border-bottom: 1px solid #dee2e6;
            display: flex;
            align-items: center;
            padding: 0.375rem 0.75rem;
            color: #6c757d;
            border-top-right-radius: 0.375rem;
            border-bottom-right-radius: 0.375rem;
        }

        .btn-primary-custom {
            background-color: #0b1354;
            border: none;
            padding: 12px;
            font-weight: 600;
            border-radius: 8px;
            width: 100%;
            margin-top: 20px;
        }

            .btn-primary-custom:hover {
                background-color: #080d3b;
            }

        /* Right Side: Banner */
        .auth-banner-section {
            flex: 1;
            background-color: #3b4cca;
            color: white;
            padding: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .banner-icon {
            font-size: 80px;
            color: #ffd700; /* Duck yellow */
            margin-bottom: 20px;
        }

        .banner-title {
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 20px;
        }

            .banner-title span {
                color: #ffd700;
            }

        .banner-text {
            font-size: 1rem;
            opacity: 0.9;
            margin-bottom: 40px;
            line-height: 1.6;
        }

        .stats-container {
            display: flex;
            gap: 15px;
            width: 100%;
            justify-content: center;
        }

        .stat-box {
            background: rgba(255, 255, 255, 0.1);
            padding: 15px;
            border-radius: 10px;
            flex: 1;
            backdrop-filter: blur(5px);
        }

        .stat-number {
            font-size: 1.5rem;
            font-weight: bold;
            display: block;
        }

        .stat-label {
            font-size: 0.8rem;
            opacity: 0.8;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

    <div class="auth-container">

        <div class="auth-form-section">
            <div class="auth-logo">
                <i class="fas fa-bolt" style="font-size: 40px; color: #0b1354; background: #eef2ff; padding: 10px 15px; border-radius: 10px;"></i>
                <h4 class="mt-2 mb-0" style="color: #0b1354; font-weight: 700;">Route Fitness</h4>
                <small class="text-muted">Gym Management System</small>
            </div>

            <h3 class="auth-title">Create Account</h3>
            <p class="auth-subtitle">Join us today! Please fill in your details</p>

            @{
                // Extract the custom Identity errors using the specific key provided from the Controller
                var registerError = ViewData.ModelState["Register Failure"]?.Errors.FirstOrDefault()?.ErrorMessage;
            }

            @if (!string.IsNullOrEmpty(registerError))
            {
                <div class="alert alert-danger p-3 small shadow-sm alert-dismissible fade show d-flex align-items-center" role="alert" style="border-radius: 10px; font-weight: 500; margin-bottom: 20px;">
                    <i class="fas fa-exclamation-triangle me-2 fs-5"></i>
                    <div>
                        @registerError
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="Register" asp-controller="Account" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                            <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                        </div>
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                            <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                        </div>
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-id-badge"></i></span>
                        <input asp-for="UserName" class="form-control" placeholder="Username" autocomplete="username" />
                    </div>
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="Email Address" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-phone"></i></span>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input asp-for="Password" class="form-control" id="passwordInput" placeholder="Password" style="border-right: none;" autocomplete="new-password" />
                        <span class="toggle-password" onclick="togglePassword('passwordInput', 'togglePasswordIcon')">
                            <i class="fas fa-eye-slash" id="togglePasswordIcon"></i>
                        </span>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input asp-for="ConfirmPassword" class="form-control" id="confirmPasswordInput" placeholder="Confirm Password" style="border-right: none;" autocomplete="new-password" />
                        <span class="toggle-password" onclick="togglePassword('confirmPasswordInput', 'toggleConfirmIcon')">
                            <i class="fas fa-eye-slash" id="toggleConfirmIcon"></i>
                        </span>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-primary-custom">
                    <i class="fas fa-user-plus me-2"></i> REGISTER ACCOUNT
                </button>

                <div class="text-center mt-3">
                    <small class="text-muted">Already have an account? <a asp-action="Login" asp-controller="Account" asp-route-returnurl="@ViewData["ReturnUrl"]" style="color: #0b1354; font-weight: bold; text-decoration: none;">Login here</a></small>
                </div>
            </form>
        </div>

        <div class="auth-banner-section d-none d-md-flex">
            <i class="fas fa-hand-rock banner-icon"></i>

            <h2 class="banner-title">Your body can <span>stand</span><br>almost anything</h2>

            <p class="banner-text">
                It's your mind that needs convincing. Push past your limits,<br>
                stay committed, and watch as your body transforms into<br>
                powerhouse of strength and resilience.
            </p>

            <div class="stats-container">
                <div class="stat-box">
                    <span class="stat-number">500+</span>
                    <span class="stat-label">Members</span>
                </div>
                <div class="stat-box">
                    <span class="stat-number">50+</span>
                    <span class="stat-label">Trainers</span>
                </div>
                <div class="stat-box">
                    <span class="stat-number">24/7</span>
                    <span class="stat-label">Support</span>
                </div>
            </div>
        </div>

    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            } else {
                input.type = "password";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            }
        }
    </script>
    <script>

                $(function() {
            // Check if the registration failure alert exists
            const alertBox = $('.alert-danger');

            if (alertBox.length > 0) {
                // Auto-hide the registration failure message after 5 seconds (5000ms)
                setTimeout(function () {
                    alertBox.fadeOut('slow', function () {
                        $(this).remove(); // Completely remove from DOM after fading out
                    });
                }, 5000);
            }
        });
    </script>
</body>
</html>